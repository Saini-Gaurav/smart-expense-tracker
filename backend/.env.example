# ============================================
# Smart Expense Tracker - Backend Environment
# ============================================

PORT=
NODE_ENV=

# Deploying on Render (free tier): the service sleeps after idle time. The first request
# after sleep can take ~30–60 seconds (cold start); later requests are fast. This is
# expected — not a bug. Paid plans or always-on options avoid sleep.

# Atlas (copy full string from Atlas → Connect → Drivers). Host must include the random id, e.g. cluster0.xxxxx.mongodb.net
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/expense_tracker?retryWrites=true&w=majority
# Local MongoDB (no Atlas):
# MONGODB_URI=mongodb://127.0.0.1:27017/expense_tracker
MONGODB_URI=

JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_TOKEN_DAYS=7

CLIENT_URL=

RATE_LIMIT_WINDOW_MS=
RATE_LIMIT_MAX_REQUESTS=